generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String
  image         String?    @db.Text
  passwordHash  String?
  role          Role       @default(COLLEGE_EDITOR)
  collegeId     String?
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  approvals     Approval[]
  auditLogs     AuditLog[]
  uploadedMedia Media[]
  authoredPosts Post[]     @relation("PostAuthor")
  reviewedPosts Post[]     @relation("PostReviewer")
  sessions      Session[]

  @@index([collegeId])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.Text
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id              String           @id @default(cuid())
  type            PostType         @default(NEWS)
  title           String           @db.Text
  slug            String
  excerpt         String?          @db.Text
  content         Json
  contentText     String?          @db.Text
  coverImageUrl   String?          @db.Text
  coverImageAlt   String?          @db.Text
  status          PostStatus       @default(DRAFT)
  isFeatured      Boolean          @default(false)
  viewCount       Int              @default(0)
  authorId        String
  originCollegeId String?
  reviewedById    String?
  reviewedAt      DateTime?
  submittedAt     DateTime?
  publishedAt     DateTime?
  scheduledFor    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sdgs            Json?
  approvals       Approval[]
  author          User             @relation("PostAuthor", fields: [authorId], references: [id])
  reviewedBy      User?            @relation("PostReviewer", fields: [reviewedById], references: [id])
  collegeTags     PostCollegeTag[]
  revisions       PostRevision[]

  @@unique([originCollegeId, slug])
  @@index([status, publishedAt])
  @@index([originCollegeId, status, publishedAt])
  @@index([type, status, publishedAt])
  @@index([authorId])
}

model PostCollegeTag {
  postId    String
  collegeId String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, collegeId])
  @@index([collegeId])
}

model Approval {
  id        String         @id @default(cuid())
  postId    String
  actorId   String
  action    ApprovalAction
  comment   String?        @db.Text
  createdAt DateTime       @default(now())
  actor     User           @relation(fields: [actorId], references: [id])
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model PostRevision {
  id        String   @id @default(cuid())
  postId    String
  title     String   @db.Text
  content   Json
  editorId  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Media {
  id           String    @id @default(cuid())
  url          String    @db.Text
  type         MediaType @default(IMAGE)
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  alt          String?   @db.Text
  caption      String?   @db.Text
  uploadedById String
  collegeId    String?
  createdAt    DateTime  @default(now())
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  @@index([collegeId, createdAt])
  @@index([uploadedById])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([createdAt])
}

enum Role {
  SUPER_ADMIN
  COLLEGE_ADMIN
  COLLEGE_EDITOR
}

enum PostType {
  NEWS
  BLOG
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ApprovalAction {
  SUBMIT
  APPROVE
  REJECT
  REQUEST_CHANGES
  PUBLISH
  UNPUBLISH
  ARCHIVE
}

enum MediaType {
  IMAGE
  DOCUMENT
  VIDEO
  OTHER
}
